generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String         @id @default(cuid())
  email                String         @unique
  password             String
  firstName            String
  lastName             String
  role                 Role
  isActive             Boolean        @default(true)
  permissions          Permission[]   @default([])
  totpSecret           String?
  totpEnabled          Boolean        @default(false)
  lastActivityAt       DateTime?
  currentSessionId     String?
  createdById          String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  auditLogs            AuditLog[]
  notifications        Notification[]
  refreshTokens        RefreshToken[]
  receivedTransactions Transaction[]  @relation("ReceiverAgent")
  sentTransactions     Transaction[]  @relation("SenderAgent")
  createdBy            User?          @relation("CreatedUsers", fields: [createdById], references: [id])
  createdUsers         User[]         @relation("CreatedUsers")
  zones                UserZone[]

  @@index([email])
  @@index([role])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Zone {
  id                 String         @id @default(cuid())
  name               String         @unique
  currency           String
  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  destRates          ExchangeRate[] @relation("DestRateZone")
  sourceRates        ExchangeRate[] @relation("SourceRateZone")
  destTransactions   Transaction[]  @relation("DestZone")
  sourceTransactions Transaction[]  @relation("SourceZone")
  users              UserZone[]
}

model UserZone {
  id     String @id @default(cuid())
  userId String
  zoneId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  zone   Zone   @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([userId, zoneId])
  @@index([userId])
  @@index([zoneId])
}

model ExchangeRate {
  id           String     @id @default(cuid())
  sourceZoneId String
  destZoneId   String
  rate         Decimal    @db.Decimal(18, 6)
  source       RateSource
  isActive     Boolean    @default(true)
  setById      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  destZone     Zone       @relation("DestRateZone", fields: [destZoneId], references: [id])
  sourceZone   Zone       @relation("SourceRateZone", fields: [sourceZoneId], references: [id])

  @@index([sourceZoneId, destZoneId])
  @@index([isActive])
}

model Transaction {
  id              String            @id @default(cuid())
  code            String            @unique
  sourceAmount    Int
  sourceCurrency  String
  destAmount      Int
  destCurrency    String
  appliedRate     Decimal           @db.Decimal(18, 6)
  rateSource      RateSource
  sourceZoneId    String
  destZoneId      String
  senderAgentId   String
  receiverAgentId String?
  recipientName   String
  status          TransactionStatus @default(PENDING)
  expiresAt       DateTime?
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  senderName      String
  destZone        Zone              @relation("DestZone", fields: [destZoneId], references: [id])
  receiverAgent   User?             @relation("ReceiverAgent", fields: [receiverAgentId], references: [id])
  senderAgent     User              @relation("SenderAgent", fields: [senderAgentId], references: [id])
  sourceZone      Zone              @relation("SourceZone", fields: [sourceZoneId], references: [id])

  @@index([code])
  @@index([status])
  @@index([senderAgentId])
  @@index([receiverAgentId])
  @@index([sourceZoneId])
  @@index([destZoneId])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

enum Role {
  OWNER
  MANAGER
  AGENT
}

enum Permission {
  MANAGE_USERS
  MANAGE_ZONES
  MANAGE_RATES
  VIEW_ALL_TRANSACTIONS
  CANCEL_TRANSACTIONS
  VIEW_AUDIT_LOGS
  GENERATE_REPORTS
  FULL_ADMIN
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
  EXPIRED
}

enum RateSource {
  MANUAL
  API
}

enum NotificationType {
  TRANSACTION_CONFIRMED
  TRANSACTION_CANCELLED
  TRANSACTION_EXPIRED
  RATE_UPDATED
  USER_CREATED
  TRANSACTION_CREATED
}
