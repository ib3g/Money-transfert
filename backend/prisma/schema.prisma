generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  MANAGER
  AGENT
}

enum Permission {
  MANAGE_USERS
  MANAGE_ZONES
  MANAGE_RATES
  VIEW_ALL_TRANSACTIONS
  CANCEL_TRANSACTIONS
  VIEW_AUDIT_LOGS
  GENERATE_REPORTS
  FULL_ADMIN
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
  EXPIRED
}

enum RateSource {
  MANUAL
  API
}

enum NotificationType {
  TRANSACTION_CONFIRMED
  TRANSACTION_CANCELLED
  TRANSACTION_EXPIRED
  RATE_UPDATED
  USER_CREATED
}

model User {
  id               String       @id @default(cuid())
  email            String       @unique
  password         String
  firstName        String
  lastName         String
  role             Role
  isActive         Boolean      @default(true)
  permissions      Permission[] @default([])
  totpSecret       String?
  totpEnabled      Boolean      @default(false)
  lastActivityAt   DateTime?
  currentSessionId String?

  zones                UserZone[]
  refreshTokens        RefreshToken[]
  sentTransactions     Transaction[]  @relation("SenderAgent")
  receivedTransactions Transaction[]  @relation("ReceiverAgent")
  notifications        Notification[]
  auditLogs            AuditLog[]

  createdById  String?
  createdBy    User?   @relation("CreatedUsers", fields: [createdById], references: [id])
  createdUsers User[]  @relation("CreatedUsers")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model Zone {
  id       String  @id @default(cuid())
  name     String  @unique
  currency String
  isActive Boolean @default(true)

  users              UserZone[]
  sourceTransactions Transaction[]  @relation("SourceZone")
  destTransactions   Transaction[]  @relation("DestZone")
  sourceRates        ExchangeRate[] @relation("SourceRateZone")
  destRates          ExchangeRate[] @relation("DestRateZone")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserZone {
  id     String @id @default(cuid())
  userId String
  zoneId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  zone   Zone   @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([userId, zoneId])
  @@index([userId])
  @@index([zoneId])
}

model ExchangeRate {
  id           String     @id @default(cuid())
  sourceZoneId String
  destZoneId   String
  rate         Decimal    @db.Decimal(18, 6)
  source       RateSource
  isActive     Boolean    @default(true)
  setById      String?

  sourceZone Zone @relation("SourceRateZone", fields: [sourceZoneId], references: [id])
  destZone   Zone @relation("DestRateZone",   fields: [destZoneId],   references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sourceZoneId, destZoneId])
  @@index([isActive])
}

model Transaction {
  id              String            @id @default(cuid())
  code            String            @unique
  sourceAmount    Int
  sourceCurrency  String
  destAmount      Int
  destCurrency    String
  appliedRate     Decimal           @db.Decimal(18, 6)
  rateSource      RateSource
  sourceZoneId    String
  destZoneId      String
  senderAgentId   String
  receiverAgentId String?
  recipientName   String
  status          TransactionStatus @default(PENDING)
  expiresAt       DateTime?
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?

  sourceZone    Zone  @relation("SourceZone",    fields: [sourceZoneId],  references: [id])
  destZone      Zone  @relation("DestZone",      fields: [destZoneId],    references: [id])
  senderAgent   User  @relation("SenderAgent",   fields: [senderAgentId], references: [id])
  receiverAgent User? @relation("ReceiverAgent", fields: [receiverAgentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([status])
  @@index([senderAgentId])
  @@index([receiverAgentId])
  @@index([sourceZoneId])
  @@index([destZoneId])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}
